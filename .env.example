# Copy to .env:  cp .env.example .env
#
# 1) Start Postgres:  docker compose up -d
# 2) Apply schema:    npx prisma migrate deploy
# 3) (optional) Seed:  npm run db:seed

# Optional: set POSTGRES_PORT=5434 in .env if host 5432 is already in use (Docker Compose reads this).
# DATABASE_URL host port must match the published Postgres port.
DATABASE_URL="postgresql://ecommerce:ecommerce@localhost:5434/ecommerce?schema=public"

JWT_SECRET=replace-with-a-long-random-string-at-least-32-characters
# Match docker-compose Redis host port (default 6379; use 6380 if 6379 is busy — set REDIS_PORT in .env for Compose).
REDIS_URL=redis://localhost:6379
PORT=3000

# Wipe catalog and re-seed:  npm run db:seed:reset
# SEED_RESET=true
