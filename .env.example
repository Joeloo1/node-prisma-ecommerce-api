# ====================
# BACKEND SETTINGS
# ====================
# Database connection for Prisma
# Make sure this matches the port exposed by docker-compose
DATABASE_URL="postgresql://ecommerce:ecommerce@localhost:5434/ecommerce?schema=public"

# Redis connection
REDIS_URL="redis://localhost:6379"

# Application port (Backend will run here)
PORT=3000

# Authentication
JWT_SECRET="replace-with-a-long-random-string-at-least-32-characters"

# Seed configuration (Optional)
# SEED_RESET=true

# ====================
# FRONTEND SETTINGS
# ====================
# Usually, Vite automatically uses the port 5173, and requests to /api might be proxied to localhost:3000
# Add any Vite-specific environment variables here (must start with VITE_)
# VITE_API_URL="http://localhost:3000/api"
